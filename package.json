{
  "name": "@gahojin-inc/date-fns-japan",
  "version": "2026.4.0",
  "description": "date-fns plugin for japan",
  "author": "GAHOJIN, Inc.",
  "license": "Apache-2.0",
  "sideEffects": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/date-fns-japan.git"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "date-fns"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "rolldown -c",
    "prepublishOnly": "pnpm run build",
    "lint": "biome check --write .",
    "check": "tsgo",
    "check:packagejson": "pnpm attw --profile esm-only --pack .",
    "test": "vitest --watch",
    "test:unit": "vitest --passWithNoTests --run --coverage",
    "bench": "vitest bench",
    "ncu": "mise run ncu"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./addJapan": {
      "import": {
        "types": "./dist/addJapan/index.d.ts",
        "default": "./dist/addJapan/index.js"
      }
    },
    "./isAfterDay": {
      "import": {
        "types": "./dist/isAfterDay/index.d.ts",
        "default": "./dist/isAfterDay/index.js"
      }
    },
    "./isBeforeDay": {
      "import": {
        "types": "./dist/isBeforeDay/index.d.ts",
        "default": "./dist/isBeforeDay/index.js"
      }
    },
    "./isWithinGtfsCalendar": {
      "import": {
        "types": "./dist/isWithinGtfsCalendar/index.d.ts",
        "default": "./dist/isWithinGtfsCalendar/index.js"
      }
    },
    "./normalizeDuration": {
      "import": {
        "types": "./dist/normalizeDuration/index.d.ts",
        "default": "./dist/normalizeDuration/index.js"
      }
    },
    "./subJapan": {
      "import": {
        "types": "./dist/subJapan/index.d.ts",
        "default": "./dist/subJapan/index.js"
      }
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.10",
    "@date-fns/tz": "1.4.1",
    "@fast-check/vitest": "0.3.0",
    "@types/node": "24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260324.1",
    "@vitest/coverage-v8": "4.1.2",
    "date-fns": "4.1.0",
    "iso8601-duration": "2.1.3",
    "jest-extended": "7.0.0",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "date-fns": "^4"
  },
  "packageManager": "pnpm@10.33.0"
}
